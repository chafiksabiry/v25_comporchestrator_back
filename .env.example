# PayPal Sandbox — copy Client ID + Secret from developer.paypal.com → Apps & Credentials → Sandbox
# Do NOT deploy these placeholder values to Railway; OAuth will return invalid_client (401).
PAYPAL_CLIENT_ID=your_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_sandbox_secret
PAYPAL_MODE=sandbox

# Frontend shell (qiankun host)
FRONTEND_BASE_URL=https://harx25pageslinks.netlify.app

# Host that serves paypal-return.html / paypal-cancel.html (orchestrator MF on Netlify)
# Must host static paypal-return.html / paypal-cancel.html (NOT the qiankun shell — pageslinks SPA catches unknown paths).
PAYPAL_RETURN_BASE_URL=https://harxv25comporchestratorfront.netlify.app

# Phone line checkout pricing (cents) — 100 = 1,00 €
PHONE_LINE_SETUP_FEE_CENTS=100
PHONE_LINE_CURRENCY=EUR

# Minutes packs: price per minute in cents (100 = 1,00 € / minute)
MINUTES_UNIT_PRICE_CENTS=100
PAYMENT_CURRENCY=EUR

# Stripe — https://dashboard.stripe.com/apikeys (use sk_test_… in dev)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Same host as PayPal return pages (stripe-return.html / stripe-cancel.html)
STRIPE_RETURN_BASE_URL=https://harxv25comporchestratorfront.netlify.app

# Public URL of THIS API (orchestrator). Injected as `apiBase` into stripe-return.html
# so the static return page can call /subscriptions/checkout/confirm or
# /payments/checkout/confirm. The frontend may override per request via
# `apiBaseUrl` in the init payload.
PUBLIC_API_BASE_URL=https://v25comporchestratorback-production.up.railway.app/api
